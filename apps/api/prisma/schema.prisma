model ComplianceOnboarding {
  id                   String                      @id @default(cuid())
  organizationId       String
  environment          String
  deviceName           String
  deviceSerial         String
  status               ComplianceOnboardingStatus  @default(DRAFT)
  certificateStatus    ComplianceCertificateStatus @default(NOT_REQUESTED)
  commonName           String?
  egsSerialNumber      String?
  organizationUnitName String?
  organizationName     String?
  countryCode          String?                     @default("SA")
  vatNumber            String?
  branchName           String?
  locationAddress      String?
  industry             String?
  csrPem               String?
  csrBase64            String?
  privateKeyPem        String?
  publicKeyPem         String?
  otpCode              String?
  otpReceivedAt        DateTime?
  csrGeneratedAt       DateTime?
  csrSubmittedAt       DateTime?
  csid                 String?
