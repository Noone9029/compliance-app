model ComplianceOnboarding {
  id                   String                      @id @default(cuid())
  organizationId       String
  environment          String
  deviceName           String
  deviceSerial         String
  status               ComplianceOnboardingStatus  @default(NOT_STARTED)
  certificateStatus    ComplianceCertificateStatus @default(NOT_REQUESTED)
  csid                 String?
  certificateId        String?
  secretFingerprint    String?
  certificateIssuedAt  DateTime?
  certificateExpiresAt DateTime?
  lastActivatedAt      DateTime?
  lastRenewedAt        DateTime?
  revokedAt            DateTime?
  lastError            String?
  metadata             Json?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  organization         Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  complianceDocuments  ComplianceDocument[]
  events               ComplianceEvent[]

  @@unique([organizationId, deviceSerial])
  @@index([organizationId, createdAt])
}

model ComplianceDocument {
  id                   String                    @id @default(cuid())
  organizationId       String
  salesInvoiceId       String                    @unique
  onboardingId         String?
  invoiceKind          ComplianceInvoiceKind
  submissionFlow       ComplianceSubmissionFlow  @default(REPORTING)
  invoiceCounter       Int                       @default(0)
  uuid                 String                    @unique
  qrPayload            String
  previousHash         String?
  currentHash          String
  xmlContent           String                    @default("")
  status               ComplianceDocumentStatus  @default(DRAFT)
  lastSubmissionStatus SubmissionStatus?
  lastSubmittedAt      DateTime?
  lastError            String?
  failureCategory      ComplianceFailureCategory?
  externalSubmissionId String?
  clearedAt            DateTime?
  reportedAt           DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  organization         Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesInvoice         SalesInvoice              @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  onboarding           ComplianceOnboarding?     @relation(fields: [onboardingId], references: [id], onDelete: SetNull)
  reportedDocument     ReportedDocument?
  submission           ZatcaSubmission?
  events               ComplianceEvent[]
  attempts             ZatcaSubmissionAttempt[]

  @@index([organizationId, status, createdAt])
}

model ReportedDocument {
  id                   String                    @id @default(cuid())
  organizationId       String
  salesInvoiceId       String                    @unique
  complianceDocumentId String                    @unique
  documentNumber       String
  status               String
  submissionFlow       ComplianceSubmissionFlow  @default(REPORTING)
  lastSubmissionStatus SubmissionStatus?
  failureCategory      ComplianceFailureCategory?
  externalSubmissionId String?
  responseCode         String?
  responseMessage      String?
  submittedAt          DateTime
  createdAt            DateTime                  @default(now())
  organization         Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesInvoice         SalesInvoice              @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  complianceDocument   ComplianceDocument        @relation(fields: [complianceDocumentId], references: [id], onDelete: Cascade)

  @@index([organizationId, submittedAt])
}

model ComplianceEvent {
  id                     String               @id @default(cuid())
  organizationId         String
  salesInvoiceId         String?
  complianceDocumentId   String?
  complianceOnboardingId String?
  zatcaSubmissionId      String?
  actorUserId            String?
  action                 String
  status                 String
  message                String?
  metadata               Json?
  createdAt              DateTime             @default(now())
  organization           Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesInvoice           SalesInvoice?        @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  complianceDocument     ComplianceDocument?  @relation(fields: [complianceDocumentId], references: [id], onDelete: Cascade)
  complianceOnboarding   ComplianceOnboarding? @relation(fields: [complianceOnboardingId], references: [id], onDelete: Cascade)
  zatcaSubmission        ZatcaSubmission?     @relation(fields: [zatcaSubmissionId], references: [id], onDelete: Cascade)
  actorUser              User?                @relation("ComplianceEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
}

model ZatcaSubmission {
  id                   String                    @id @default(cuid())
  organizationId       String
  complianceDocumentId String                    @unique
  requestedByUserId    String?
  flow                 ComplianceSubmissionFlow  @default(REPORTING)
  status               SubmissionStatus          @default(QUEUED)
  retryable            Boolean                   @default(false)
  attemptCount         Int                       @default(0)
  maxAttempts          Int                       @default(5)
  availableAt          DateTime                  @default(now())
  lockedAt             DateTime?
  nextRetryAt          DateTime?
  lastAttemptAt        DateTime?
  requestPayload       Json?
  responsePayload      Json?
  errorMessage         String?
  failureCategory      ComplianceFailureCategory?
  externalSubmissionId String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  finishedAt           DateTime?
  organization         Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  complianceDocument   ComplianceDocument        @relation(fields: [complianceDocumentId], references: [id], onDelete: Cascade)
  attempts             ZatcaSubmissionAttempt[]
  events               ComplianceEvent[]

  @@index([organizationId, status, availableAt])
}

model ZatcaSubmissionAttempt {
  id                   String                    @id @default(cuid())
  organizationId       String
  complianceDocumentId String
  zatcaSubmissionId    String
  attemptNumber        Int
  flow                 ComplianceSubmissionFlow  @default(REPORTING)
  status               SubmissionStatus          @default(QUEUED)
  retryable            Boolean                   @default(false)
  endpoint             String
  httpStatus           Int?
  failureCategory      ComplianceFailureCategory?
  externalSubmissionId String?
  requestPayload       Json?
  responsePayload      Json?
  errorMessage         String?
  startedAt            DateTime                  @default(now())
  finishedAt           DateTime?
  organization         Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  complianceDocument   ComplianceDocument        @relation(fields: [complianceDocumentId], references: [id], onDelete: Cascade)
  zatcaSubmission      ZatcaSubmission           @relation(fields: [zatcaSubmissionId], references: [id], onDelete: Cascade)

  @@index([organizationId, startedAt])
  @@index([zatcaSubmissionId, attemptNumber])
}

