  createdAt            DateTime                   @default(now())
  externalSubmissionId String?
  failureCategory      ComplianceFailureCategory?
  lastSubmissionStatus SubmissionStatus?
  submissionFlow       ComplianceSubmissionFlow   @default(REPORTING)
  complianceDocument   ComplianceDocument         @relation(fields: [complianceDocumentId], references: [id], onDelete: Cascade)
  organization         Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesInvoice         SalesInvoice               @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)

  @@index([organizationId, submittedAt])
}

model ComplianceEvent {
  id                     String                @id @default(cuid())
  organizationId         String
  salesInvoiceId         String?
  complianceDocumentId   String?
  actorUserId            String?
  action                 String
  status                 String
  message                String?
  metadata               Json?
  createdAt              DateTime              @default(now())
  complianceOnboardingId String?
  zatcaSubmissionId      String?
  actorUser              User?                 @relation("ComplianceEventActor", fields: [actorUserId], references: [id])
  complianceDocument     ComplianceDocument?   @relation(fields: [complianceDocumentId], references: [id], onDelete: Cascade)
  complianceOnboarding   ComplianceOnboarding? @relation(fields: [complianceOnboardingId], references: [id], onDelete: Cascade)
  organization           Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesInvoice           SalesInvoice?         @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  zatcaSubmission        ZatcaSubmission?      @relation(fields: [zatcaSubmissionId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model ZatcaSubmission {
  id                   String                     @id @default(cuid())
  organizationId       String
  complianceDocumentId String                     @unique
  status               SubmissionStatus           @default(QUEUED)
  retryable            Boolean                    @default(false)
  requestPayload       Json?
  responsePayload      Json?
  errorMessage         String?
  finishedAt           DateTime?
  attemptCount         Int                        @default(0)
  availableAt          DateTime                   @default(now())
  createdAt            DateTime                   @default(now())
  externalSubmissionId String?
  failureCategory      ComplianceFailureCategory?
  flow                 ComplianceSubmissionFlow   @default(REPORTING)
  lastAttemptAt        DateTime?
  lockedAt             DateTime?
  maxAttempts          Int                        @default(5)
  nextRetryAt          DateTime?
  requestedByUserId    String?
  updatedAt            DateTime                   @updatedAt
  events               ComplianceEvent[]
  complianceDocument   ComplianceDocument         @relation(fields: [complianceDocumentId], references: [id], onDelete: Cascade)
  organization         Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  attempts             ZatcaSubmissionAttempt[]

  @@index([organizationId, status, availableAt])
}

model ZatcaSubmissionAttempt {
  id                   String                     @id @default(cuid())
  organizationId       String
  complianceDocumentId String
  zatcaSubmissionId    String
  attemptNumber        Int
