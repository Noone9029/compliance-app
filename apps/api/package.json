{
  "name": "@daftar/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts",
    "envFile": "../../.env"
  },
  "scripts": {
    "prisma:generate": "pnpm --dir ../.. exec prisma generate --schema apps/api/prisma/schema.prisma",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --dir ../.. db:seed && vitest run --passWithNoTests",
    "test:sdk-parity": "vitest run src/modules/compliance/sdk-parity.service.spec.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@daftar/config": "workspace:*",
    "@daftar/types": "workspace:*",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@peculiar/x509": "^2.0.0",
    "@prisma/client": "^6.19.3",
    "@xmldom/xmldom": "^0.9.10",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.58.0",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.8.1",
    "pdf-lib": "^1.17.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsx": "^4.20.5",
    "uuid": "^13.0.0",
    "xml-crypto-next": "^8.0.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.6",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.19.3",
    "supertest": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
