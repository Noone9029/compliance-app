#
# Daftar workspace environment template
# Copy this file to .env for local development.
# For hosted deployment, set variables per-service in the platform UI instead.
#

# -----------------------------------------------------------------------------
# Shared app identity and routing
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=Daftar
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Daftar
NEXT_PUBLIC_API_URL=http://localhost:4000
INTERNAL_API_URL=http://localhost:4000
API_PORT=4000
WEB_PORT=3000
WORKER_PORT=4010

# -----------------------------------------------------------------------------
# Core infrastructure (required for API + worker)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/daftar?schema=public
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Auth/session
# -----------------------------------------------------------------------------
SESSION_COOKIE_NAME=daftar_session
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=auto
SESSION_TTL_HOURS=12
AUTH_BCRYPT_ROUNDS=10
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Object storage (attachments/artifacts)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=daftar-local
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# -----------------------------------------------------------------------------
# Stripe (optional unless billing webhooks/payments are enabled)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# -----------------------------------------------------------------------------
# Accounting connector app credentials (optional unless connector enabled)
# -----------------------------------------------------------------------------
XERO_CLIENT_ID=placeholder
XERO_CLIENT_SECRET=placeholder
QBO_CLIENT_ID=placeholder
QBO_CLIENT_SECRET=placeholder
ZOHO_CLIENT_ID=placeholder
ZOHO_CLIENT_SECRET=placeholder
CONNECTOR_SECRETS_KEY=connector-secrets-local-dev-key

# -----------------------------------------------------------------------------
# ZATCA transport + local tooling
# -----------------------------------------------------------------------------
ZATCA_BASE_URL=https://gw-fatoora.zatca.gov.sa
ZATCA_SDK_CLI_PATH=fatoora
ZATCA_LOCAL_VALIDATION_MODE=required

# NOTE:
# ZATCA device credentials are NOT configured as global env variables.
# CSID/certificate credentials are issued through onboarding and stored per device.

# -----------------------------------------------------------------------------
# Compliance secret encryption
# -----------------------------------------------------------------------------
COMPLIANCE_ENCRYPTION_KEY=compliance-encryption-local-dev-key
COMPLIANCE_ENCRYPTION_PREVIOUS_KEYS=
