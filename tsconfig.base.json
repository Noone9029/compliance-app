{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@daftar/config": ["packages/config/src/index.ts"],
      "@daftar/types": ["packages/types/src/index.ts"],
      "@daftar/ui": ["packages/ui/src/index.ts"],
      "@daftar/sdk": ["packages/sdk/src/index.ts"]
    }
  }
}
